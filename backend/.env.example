# ══════════════════════════════════════════════════════════════════
# Workforce Planning Agent — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ══════════════════════════════════════════════════════════════════

# ── Anthropic / SAP Hyperspace AI ─────────────────────────────────
# Obtain from your SAP Hyperspace account or Anthropic dashboard
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_BASE_URL=http://localhost:6655/anthropic
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── JWT Auth Secret ────────────────────────────────────────────────
# Any long random string — used to sign session tokens
TOKEN_SECRET=change-me-to-a-long-random-secret

# ── App Login Credentials ──────────────────────────────────────────
# Passwords for the 3 demo personas
EMPLOYEE_PASSWORD=emp123
MANAGER_PASSWORD=man123
EXECUTIVE_PASSWORD=exe123

# ── SAP BTP / Cloud Foundry ────────────────────────────────────────
# Used only for deployment — not needed for local development
CF_API_ENDPOINT=https://api.cf.us10-001.hana.ondemand.com
CF_ORG=8035567atrial
CF_SPACE=dev
CF_APP_NAME=workforce-planning-agent

# ── SAP Joule (future integration) ────────────────────────────────
# Required if connecting to real SAP Joule Designer (paid BTP only)
# JOULE_API_URL=https://<subaccount>.sapdas.cloud.sap
# JOULE_AUTH_URL=https://<subaccount>.authentication.sap.hana.ondemand.com
# JOULE_CLIENT_ID=
# JOULE_CLIENT_SECRET=

# ── SAP AI Core (future integration) ──────────────────────────────
# Required for SAP AI Core deployment
# AICORE_SERVICE_URL=
# AICORE_TOKEN_URL=
# AICORE_CLIENT_ID=
# AICORE_CLIENT_SECRET=
# AICORE_RESOURCE_GROUP=default
